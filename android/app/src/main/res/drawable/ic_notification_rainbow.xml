<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome rainbow: 3 concentric 270° arcs, center (18,18) in a 36x36 viewport.
  Each arc starts at 12 o'clock (top) and sweeps clockwise to 9 o'clock (left),
  leaving the upper-left gap open (= 45–60 min region on a clock face).
  Radii 16 / 10 / 4, strokeWidth 3, gap between arcs = 3 units.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="36"
    android:viewportHeight="36">
    <!-- Outer arc (r=16): from (18,2) clockwise 270° to (2,18) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M18,2 A16,16 0 1 1 2,18" />
    <!-- Middle arc (r=10): from (18,8) clockwise 270° to (8,18) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M18,8 A10,10 0 1 1 8,18" />
    <!-- Inner arc (r=4): from (18,14) clockwise 270° to (14,18) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M18,14 A4,4 0 1 1 14,18" />
</vector>
